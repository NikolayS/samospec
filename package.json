{
  "name": "samospec",
  "version": "0.0.1",
  "description": "Git-native CLI that turns a rough idea into a reviewed, versioned specification document.",
  "type": "module",
  "bin": {
    "samospec": "./src/main.ts"
  },
  "files": [
    "src",
    "package.json",
    "README.md"
  ],
  "scripts": {
    "samospec": "bun run src/main.ts",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "bun": ">=1.2.0"
  },
  "license": "UNLICENSED",
  "author": "Nikolay Samokhvalov",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NikolayS/samospec.git"
  },
  "bugs": {
    "url": "https://github.com/NikolayS/samospec/issues"
  },
  "homepage": "https://github.com/NikolayS/samospec#readme",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "^1.2.0",
    "eslint": "^10.2.1",
    "prettier": "^3.8.3",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.58.2"
  }
}
